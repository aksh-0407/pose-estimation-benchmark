# =============================================================================
# What goes to Git, in one rule:
#   Commit SOURCE (code, configs, docs) and compact EVIDENCE
#   (benchmarks/runs/<id>/). Keep ASSETS (weights, datasets, clones), RAW
#   artifacts, and DERIVED aggregates local. Full policy: docs/collaboration.md
# Anything ignored below is enforced by: python3 scripts/audit_repo.py --fail
# =============================================================================

# --- Python / cache artifacts ---
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Local assistant / editor state ---
.agents/
.codex/
.claude/
.github/modernize/
prompts/

# --- Upstream source clones and local build/env artifacts ---
# Cloned repos (MMPose, OpenPose, ...) are reproduced by setup scripts, never committed.
external/
wheels/
.model_env_stamps/

# --- Legacy paths (canonical model storage is models/<model_id>/) ---
checkpoints/
/runs/
yolo26x-pose.pt

# --- Model assets: track metadata, keep weights/checksums local ---
models/*/weights/*
!models/*/weights/.gitkeep
models/*/checksums/*
!models/*/checksums/.gitkeep

# --- Datasets and downloaded archives (local only) ---
data/raw/*
!data/raw/.gitkeep
data/derived/*
!data/derived/.gitkeep
benchmarks/datasets/*
!benchmarks/datasets/.gitkeep
*.zip
*.tar
*.tar.gz
*.tgz
*.tmp

# --- Benchmark evidence: COMMIT compact runs, IGNORE raw artifacts ---
# benchmarks/runs/<id>/ is intentionally NOT ignored: it is the committed
# evidence layer (manifests + metrics). Only raw payloads are excluded.
benchmarks/artifacts/*
!benchmarks/artifacts/.gitkeep
benchmarks/runs/*/predictions/*
benchmarks/runs/*/logs/*

# --- Derived comparison outputs (generated by aggregate/report; CI publishes them) ---
# results/*.csv and benchmarks/reports/*.html are a pure function of the run
# folders, so they are regenerated, never hand-committed. See docs/collaboration.md
results/*
!results/.gitkeep
!results/README.md
benchmarks/reports/*
!benchmarks/reports/.gitkeep
!benchmarks/reports/README.md

# --- Local research/reference dump; curate source-worthy notes into docs/ ---
Papers/
