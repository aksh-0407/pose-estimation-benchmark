# =============================================================================
# What goes to Git, in one rule:
#   Commit SOURCE (code under src/, configs, docs) only. Keep ASSETS (weights,
#   datasets, upstream clones) and all pipeline OUTPUTS (data/derived/) local.
#   Full policy: docs/shared-data.md
# Anything ignored below is enforced by: python3 tools/audit_repo.py --fail
# =============================================================================

# --- Python / cache artifacts ---
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/

# --- Local assistant / editor state (local-only, never synced) ---
.agents/
.codex/
.claude/
.vscode/
.github/modernize/
prompts/

# --- Upstream source clones and local build/env artifacts ---
# Cloned repos (MMPose, OpenPose, ...) are reproduced by setup scripts, never committed.
external/
wheels/
.model_env_stamps/

# --- Legacy paths (canonical model storage is models/<model_id>/) ---
checkpoints/
/runs/

# --- Model assets: track metadata, keep weights/checksums local ---
models/*/weights/*
!models/*/weights/.gitkeep
models/*/checksums/*
!models/*/checksums/.gitkeep

# --- Datasets and downloaded archives (local only) ---
data/raw/*
!data/raw/.gitkeep
data/derived/*
!data/derived/.gitkeep
data/viz/*
!data/viz/.gitkeep
benchmarks/datasets/*
!benchmarks/datasets/.gitkeep
# Company drive: commit the docs mirror, but never the personal LaTeX report.
# (The dataset now lives under data/raw/<dataset>/, ignored above.)
drive/LaTex Files/
*.zip
*.tar
*.tar.gz
*.tgz
*.tmp

# --- Benchmarking is off `main` (lives on the `benchmark` branch); outputs are local ---
# The whole benchmarks/ tree and rendered artifacts/ are untracked here. Pipeline
# outputs now live under data/derived/ (already ignored above). Rendered video never committed.
benchmarks/
artifacts/
results/
*.mp4

# --- Local research/reference dump; curate source-worthy notes into docs/ ---
Papers/

# --- Local-only presentation handout (generated from the .md script; hidden in VS Code) ---
presentables/00_presentation_script.pdf

# --- Local-only colleague dropzones & personal reports (never synced) ---
vedant*/
report/